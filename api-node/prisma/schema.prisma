generator client {
  provider = "prisma-client-js"
}

// O Prisma precisa disso aqui só para saber qual "idioma" falar!
datasource db {
  provider = "postgresql"
}

model Produto {
  id         Int     @id @default(autoincrement())
  url        String
  precoAlvo  Float
  precoAtual String?
  titulo     String? @default("Aguardando o Go buscar...")
}